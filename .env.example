# AWS (opcional — só necessário se for usar upload_to_s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=seu-bucket-raw-ibge

# IBGE
# API pública, sem autenticação (servicodados.ibge.gov.br). Não precisa
# de chave. IBGE_ANOS define quais anos buscar por padrão ao rodar a
# extração sem passar --anos explicitamente.
# ATENÇÃO: anos de Censo (2022) não têm estimativa nessa tabela — a API
# retorna lista vazia pra eles (tratado no código, mas não adianta pedir).
IBGE_ANOS=2024,2025

# Banco (staging / warehouse local, via docker-compose.yml)
# Porta 5433 (não 5432) pra não conflitar com outro Postgres que já
# roda na sua máquina em outro projeto (container etl_postgres).
DATABASE_URL=postgresql://ibge_user:ibge_pass@localhost:5433/ibge_dw
